{
  "name": "watermelon",
  "version": "1.2.0",
  "private": true,
  "bin": {
    "watermelon": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist",
    "packages/cli/scripts",
    "packages/cli/package.json",
    "scripts/rebuild-native.mjs",
    "README.md",
    "README.ko.md"
  ],
  "workspaces": [
    "packages/*",
    "mcp"
  ],
  "scripts": {
    "postinstall": "node scripts/rebuild-native.mjs",
    "dev": "bash scripts/dev.sh start",
    "dev:stop": "bash scripts/dev.sh stop",
    "dev:restart": "bash scripts/dev.sh restart",
    "dev:status": "bash scripts/dev.sh status",
    "dev:logs": "bash scripts/dev.sh logs",
    "dev:logs:app": "bash scripts/dev.sh logs app",
    "dev:build": "bash scripts/dev.sh build",
    "dev:seed": "bash scripts/dev.sh seed",
    "dev:reset": "bash scripts/dev.sh reset",
    "dev:shell": "bash scripts/dev.sh shell",
    "dev:raw": "next dev",
    "ws": "npx tsx scripts/ws-relay.ts",
    "build": "next build --webpack",
    "build:cli": "npm run build && npm --workspace packages/cli run build",
    "start": "next start",
    "lint": "eslint",
    "build:vs": "npx tsx scripts/build-vs-frame.ts",
    "test": "npx vitest run --dir tests"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "happy-dom": "^19.0.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.32.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.9.3",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.32.0"
  }
}
