# BlueKiwi Self-Host Configuration Template
# Copy this file to .env and fill in the required values

# Database password (generate with: openssl rand -hex 16)
DB_PASSWORD=

# JWT secret for authentication (generate with: openssl rand -hex 32)
JWT_SECRET=

# Application port
APP_PORT=3100

# Team name shown in metadata and the sidebar brand area (optional)
# TEAM_NAME=Acme Product Team

# Public URL (optional — auto-detected from request headers if omitted)
# PUBLIC_URL=https://your-domain.com

# Pin a specific image version (default: latest)
# BLUEKIWI_VERSION=0.1.0

# Email (optional) — enables invite emails via Resend
# Get your API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FROM_EMAIL=BlueKiwi <noreply@yourdomain.com>
